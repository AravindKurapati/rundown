OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...
# Optional overrides (defaults shown)
LLM_MODEL_SCRIPT=gpt-5.5
LLM_MODEL_SELECT=gpt-5-nano
TTS_MODEL=eleven_multilingual_v2
# TTS_VOICE_A is an ElevenLabs voice ID, not a display name. Keys without the
# voices_read permission cannot resolve names, so use the ID. Default is the
# premade voice "Rachel".
TTS_VOICE_A=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_RATE_USD_PER_1K=0.10
OPENAI_RATE_USD_PER_1K_IN=0.0005
OPENAI_RATE_USD_PER_1K_OUT=0.0015
BUDGET_CAP_USD=20
USE_FAKES=1
