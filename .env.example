OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...
# Optional overrides (defaults shown)
LLM_MODEL_SCRIPT=gpt-5.5
TTS_MODEL=eleven_multilingual_v2
# TTS_VOICE_A is an ElevenLabs voice ID, not a display name. Keys without the
# voices_read permission cannot resolve names, so use the ID. Default is the
# premade voice "Rachel".
TTS_VOICE_A=21m00Tcm4TlvDq8ikWAM
# Delivery: base voice settings (segment energy bends stability/style around these).
TTS_STABILITY=0.42
TTS_SIMILARITY=0.78
TTS_STYLE=0.28
TTS_SPEAKER_BOOST=1
# Narration: "segmented" renders one TTS call per segment at its energy and
# assembles locally (exact durations, provider-billed cost); "single" is the
# original one-call fallback.
NARRATION_MODE=segmented
TTS_PCM_FORMAT=pcm_22050
# A quiet generated ding inside the gap between topics (0 for silence only).
TOPIC_DING=1
ELEVENLABS_RATE_USD_PER_1K=0.10
OPENAI_RATE_USD_PER_1K_IN=0.0005
OPENAI_RATE_USD_PER_1K_OUT=0.0015
BUDGET_CAP_USD=20
USE_FAKES=1
# Optional: use Postgres instead of the default local SQLite.
# Needs a driver (pip install "psycopg[binary]") and one-time migrations.
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/rundown
